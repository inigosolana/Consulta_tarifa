# Copia este archivo como .env y rellena tus credenciales

# ── LiveKit ─────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://tu-proyecto.livekit.cloud
LIVEKIT_API_KEY=tu_api_key
LIVEKIT_API_SECRET=tu_api_secret

# ── LLM / STT / TTS ─────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
DEEPGRAM_API_KEY=tu_deepgram_api_key
CARTESIA_API_KEY=tu_cartesia_api_key
VOICE_ID_ESPANOLA=cefcb124-080b-4655-b31f-932f3ee743de

# ── Yeastar P-Series ─────────────────────────────────────────────────────────
# IP o hostname de la centralita Yeastar
YEASTAR_IP=192.168.1.100
# Número de extensión de la Cola (Queue) de agentes humanos en Yeastar
YEASTAR_QUEUE_EXT=6100

# ── Opcionales ───────────────────────────────────────────────────────────────
AGENT_NAME_DISPATCH=tarifas-atencion-cliente
